# === Env vars ===
# Los secrets reales están en Kubernetes app-secrets

# Shared (same for all services)
JWT_SECRET=change-this-to-a-secure-hex-string
ENCRYPTION_KEY=change-this-to-a-32-byte-key

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_SSLMODE=disable

# Kafka
KAFKA_HOST=localhost
KAFKA_PORT=9092
KAFKA_SIGNING_KEY=change-this-to-a-separate-kafka-key

# MongoDB
MONGODB_URI=mongodb://localhost:27017/messaging

# Port por servicio (definido en deploy.yaml como containerPort, no como env var)
# notes:    8083
# otp:      8085
# password: 8084
# messaging: 3001
